{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.webp",
          "/*.png"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "question-bank",
      "urls": ["/assets/question-bank/**"],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "7d",
        "strategy": "freshness"
      }
    }
  ]
}
